# API Keys（复制此文件为 .env 并填入真实值）

# LLM API (OpenAI-compatible endpoint)
LLM_API_KEY=your_llm_api_key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Volcengine v3 TTS (标准内置音色)
VOLC_APPID=your_volc_appid
VOLC_API_KEY=your_volc_api_key

# Volcengine Voice Clone (大模型 — 可选，未开通则自动回退内置音色)
VOLC_CLONE_API_KEY=your_volc_clone_api_key
VOLC_CLONE_SECRET=your_volc_clone_secret

# 已克隆的说话人 ID（可选，若设置则跳过克隆直接使用）
VOLC_SPEAKER_ID=your_speaker_id

# 汇报人信息（可选，优先级高于 config/settings.yaml）
# PRESENTER_NAME=汇报人姓名
# PRESENTER_AFFILIATION=所属单位
# PRESENTER_DATE=2025年6月
